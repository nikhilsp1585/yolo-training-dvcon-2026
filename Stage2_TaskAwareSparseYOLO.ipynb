   "source": [
    "---\n",
    "## Cell 6 — Load DistilBERT + encode all 14 task descriptions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import time\n",
    "from transformers import DistilBertTokenizer, DistilBertModel\n",
    "\n",
    "# ── Load DistilBERT ────────────────────────────────────────────────────────\n",
    "print(\"Loading distilbert-base-uncased (~260 MB, cached after first run)...\")\n",
    "tokenizer = DistilBertTokenizer.from_pretrained(\"distilbert-base-uncased\")\n",
    "bert_model = DistilBertModel.from_pretrained(\"distilbert-base-uncased\")\n",
    "bert_model.to(DEVICE)\n",
    "bert_model.eval()\n",
    "print(\"DistilBERT ready.\")\n",
    "\n",
    "# ── Encoding function ──────────────────────────────────────────────────────\n",
    "def encode_text(text: str, max_length: int = 64) -> torch.Tensor:\n",
    "    \"\"\"Returns L2-normalised 768-d CLS embedding.\"\"\"\n",
    "    inputs = tokenizer(text, return_tensors=\"pt\", max_length=max_length,\n",
    "                       padding=\"max_length\", truncation=True)\n",
    "    inputs = {k: v.to(DEVICE) for k, v in inputs.items()}\n",
    "    with torch.no_grad():\n",
    "        out = bert_model(**inputs)\n",
    "    emb = out.last_hidden_state[:, 0, :].squeeze(0)\n",
    "    return (emb / (emb.norm() + 1e-8)).cpu()\n",
    "\n",
    "# ── Encode all 14 tasks and measure latency ───────────────────────────────\n",
    "N_LATENCY_RUNS = 15\n",
    "task_embeddings  = {}\n",
    "encoding_latency = []   # list of {task_key, label, mean_ms, std_ms}\n",
    "\n",
    "print(\"\\nEncoding all 14 task descriptions...\")\n",
    "for task_key, task in COCO_TASKS.items():\n",
    "    desc = task[\"description\"]\n",
    "\n",
    "    # Warm-up\n",
    "    for _ in range(3):\n",
    "        encode_text(desc)\n",
    "\n",
    "    # Timed runs\n",
    "    times = []\n",
    "    for _ in range(N_LATENCY_RUNS):\n",
    "        t0 = time.perf_counter()\n",
    "        emb = encode_text(desc)\n",
    "        times.append((time.perf_counter() - t0) * 1000)\n",
    "\n",
    "    task_embeddings[task_key] = emb\n",
    "    encoding_latency.append({\n",
    "        \"task_key\" : task_key,\n",
    "        \"label\"    : task[\"label\"],\n",
    "        \"mean_ms\"  : round(float(np.mean(times)), 2),\n",
    "        \"std_ms\"   : round(float(np.std(times)),  2),\n",
    "        \"min_ms\"   : round(float(np.min(times)),  2),\n",
    "        \"max_ms\"   : round(float(np.max(times)),  2),\n",
    "    })\n",
    "\n",
    "mean_encode = np.mean([l[\"mean_ms\"] for l in encoding_latency])\n",
    "print(f\"\\nAll tasks encoded. Mean latency: {mean_encode:.1f} ms / task\")\n",
    "print(f\"Embedding shape: {list(task_embeddings['T01_cooking'].shape)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## Cell 7 — Run full pipeline: YOLO → task filter → relevance metrics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Helper: run YOLO and return structured detections ─────────────────────\n",
    "def run_yolo(img_path: str) -> list:\n",
    "    res = yolo_model.predict(img_path, conf=0.25, verbose=False, device=DEVICE)\n",
    "    dets = []\n",
    "    for r in res:\n",
    "        for box in r.boxes:\n",
    "            cid = int(box.cls.item())\n",
    "            dets.append({\n",
    "                \"class_id\"  : cid,\n",
    "                \"class_name\": yolo_model.names[cid],\n",
    "                \"confidence\": float(box.conf.item()),\n",
    "                \"bbox\"      : box.xyxy[0].tolist(),\n",
    "            })\n",
    "    return sorted(dets, key=lambda x: x[\"confidence\"], reverse=True)\n",
    "\n",
    "# ── Helper: hard filter (binary task relevance) ───────────────────────────\n",
    "def filter_detections(dets: list, task_key: str) -> dict:\n",
    "    relevant_ids = set(COCO_TASKS[task_key][\"relevant_ids\"])\n",
    "    filtered = [d for d in dets if d[\"class_id\"] in relevant_ids]\n",
    "    n_before = len(dets)\n",
    "    n_after  = len(filtered)\n",
    "    return {\n",
    "        \"filtered\"        : filtered,\n",
    "        \"n_before\"        : n_before,\n",
    "        \"n_after\"         : n_after,\n",
    "        \"suppression_pct\" : round((n_before - n_after) / n_before * 100, 1)\n",
    "                            if n_before > 0 else 0.0,\n",
    "        \"top_detection\"   : filtered[0][\"class_name\"] if filtered else None,\n",
    "    }\n",
    "\n",
    "# ── Helper: precision + recall ────────────────────────────────────────────\n",
    "def task_relevance_metrics(dets: list, task_key: str) -> dict:\n",
    "    relevant_ids = set(COCO_TASKS[task_key][\"relevant_ids\"])\n",
    "    def prec_at_k(k):\n",
    "        top = dets[:k]\n",
    "        if not top: return 0.0\n",
    "        return round(sum(1 for d in top if d[\"class_id\"] in relevant_ids) / len(top), 3)\n",
    "    detected_ids = {d[\"class_id\"] for d in dets}\n",
    "    recall = round(len(detected_ids & relevant_ids) / len(relevant_ids), 3) \\\n",
    "             if relevant_ids else 0.0\n",
    "    return {\"p1\": prec_at_k(1), \"p3\": prec_at_k(3), \"p5\": prec_at_k(5), \"recall\": recall}\n",
    "\n",
    "# ── Main loop ─────────────────────────────────────────────────────────────\n",
    "per_image_results = []\n",
    "\n",
    "for img_path in tqdm(image_paths, desc=\"Detection + filtering\"):\n",
    "    dets = run_yolo(str(img_path))\n",
    "    entry = {\"image\": img_path.name, \"n_raw\": len(dets), \"tasks\": {}}\n",
    "\n",
    "    for task_key in TASK_KEYS:\n",
    "        fr  = filter_detections(dets, task_key)\n",
    "        rel = task_relevance_metrics(dets, task_key)\n",
    "        entry[\"tasks\"][task_key] = {**fr, **rel}\n",
    "\n",
    "    per_image_results.append(entry)\n",
    "\n",
    "# ── Aggregate per-task metrics ─────────────────────────────────────────────\n",
    "task_metrics = {}\n",
    "for task_key in TASK_KEYS:\n",
    "    p1s   = [e[\"tasks\"][task_key][\"p1\"]               for e in per_image_results]\n",
    "    p3s   = [e[\"tasks\"][task_key][\"p3\"]               for e in per_image_results]\n",
    "    supps = [e[\"tasks\"][task_key][\"suppression_pct\"]   for e in per_image_results]\n",
    "    recs  = [e[\"tasks\"][task_key][\"recall\"]            for e in per_image_results]\n",
    "    task_metrics[task_key] = {\n",
    "        \"label\"         : COCO_TASKS[task_key][\"label\"],\n",
    "        \"mean_p1\"       : round(float(np.mean(p1s)),   3),\n",
    "        \"mean_p3\"       : round(float(np.mean(p3s)),   3),\n",
    "        \"mean_recall\"   : round(float(np.mean(recs)),  3),\n",
    "        \"mean_suppression_pct\": round(float(np.mean(supps)), 1),\n",
    "    }\n",
    "\n",
    "print(f\"\\nProcessed {len(per_image_results)} images across 14 tasks.\")\n",
    "print(f\"Mean Precision@1 : {np.mean([v['mean_p1'] for v in task_metrics.values()]):.3f}\")\n",
    "print(f\"Mean suppression : {np.mean([v['mean_suppression_pct'] for v in task_metrics.values()]):.1f}%\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## Cell 8 — Latency measurement: sequential vs pipelined"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "LATENCY_SAMPLE = image_paths[:5]   # 5-image batch (matches Stage 1 report claim)\n",
    "REF_TASK = \"T01_cooking\"\n",
    "\n",
    "# ── Sequential: YOLO + encode + filter, back-to-back ─────────────────────\n",
    "seq_times = []\n",
    "for img_path in LATENCY_SAMPLE:\n",
    "    t0 = time.perf_counter()\n",
    "    dets = run_yolo(str(img_path))\n",
    "    encode_text(COCO_TASKS[REF_TASK][\"description\"])\n",
    "    filter_detections(dets, REF_TASK)\n",
    "    seq_times.append((time.perf_counter() - t0) * 1000)\n",
    "\n",
    "seq_mean   = float(np.mean(seq_times))\n",
    "seq_total  = float(np.sum(seq_times))\n",
    "\n",
    "# ── Pipelined: encoder runs once; YOLO is the bottleneck per stage ────────\n",
    "yolo_times = []\n",
    "for img_path in LATENCY_SAMPLE:\n",
    "    t0 = time.perf_counter()\n",
    "    run_yolo(str(img_path))\n",
    "    yolo_times.append((time.perf_counter() - t0) * 1000)\n",
    "\n",
    "t0 = time.perf_counter()\n",
    "encode_text(COCO_TASKS[REF_TASK][\"description\"])\n",
    "encode_ms = (time.perf_counter() - t0) * 1000\n",
    "\n",
    "mean_yolo_ms   = float(np.mean(yolo_times))\n",
    "pipeline_stage = max(mean_yolo_ms, encode_ms)   # bottleneck\n",
    "pipe_total     = pipeline_stage * len(LATENCY_SAMPLE)\n",
    "pipe_per_img   = pipe_total / len(LATENCY_SAMPLE)\n",
    "speedup        = round(seq_mean / pipe_per_img, 2)\n",
    "\n",
    "latency_report = {\n",
    "    \"sequential\" : {\"mean_ms_per_image\": round(seq_mean, 1), \"total_ms\": round(seq_total, 1)},\n",
    "    \"pipelined\"  : {\"ms_per_image\": round(pipe_per_img, 1),  \"total_ms\": round(pipe_total, 1)},\n",
    "    \"speedup_x\"  : speedup,\n",
    "    \"n_images\"   : len(LATENCY_SAMPLE),\n",
    "}\n",
    "\n",
    "print(f\"\\n{'='*50}\")\n",
    "print(f\"  LATENCY REPORT ({len(LATENCY_SAMPLE)}-image batch)\")\n",
    "print(f\"{'='*50}\")\n",
    "print(f\"  YOLO inference       : {mean_yolo_ms:.1f} ms/image\")\n",
    "print(f\"  DistilBERT encode    : {encode_ms:.1f} ms (amortised)\")\n",
    "print(f\"  Sequential total     : {seq_total:.0f} ms  ({seq_mean:.1f} ms/img)\")\n",
    "print(f\"  Pipelined total      : {pipe_total:.0f} ms  ({pipe_per_img:.1f} ms/img)\")\n",
    "print(f\"  Effective speedup    : {speedup}×\")"
   ]
  },
