  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## Cell 5 — Activation sparsity measurement\n",
    "Attaches hooks to every `Conv2d / SiLU / ReLU` layer and counts zero-valued activations after the forward pass."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Hook infrastructure ────────────────────────────────────────────────────\n",
    "activation_store = {}   # layer_name → last activation tensor\n",
    "hook_handles = []\n",
    "\n",
    "def make_hook(name):\n",
    "    def hook(module, input, output):\n",
    "        activation_store[name] = output.detach().cpu()\n",
    "    return hook\n",
    "\n",
    "# Register hooks on the underlying PyTorch model\n",
    "pt_model = yolo_model.model.model\n",
    "for name, module in pt_model.named_modules():\n",
    "    if isinstance(module, (nn.Conv2d, nn.SiLU, nn.ReLU)):\n",
    "        h = module.register_forward_hook(make_hook(name))\n",
    "        hook_handles.append(h)\n",
    "\n",
    "print(f\"Registered hooks on {len(hook_handles)} layers.\")\n",
    "\n",
    "# ── Sparsity measurement over N images ───────────────────────────────────\n",
    "SPARSITY_SAMPLE = image_paths[:20]   # use first 20 for stable average\n",
    "\n",
    "all_layer_sparsity = {}   # layer_name → list of sparsity values across images\n",
    "\n",
    "for img_path in tqdm(SPARSITY_SAMPLE, desc=\"Measuring sparsity\"):\n",
    "    activation_store.clear()\n",
    "    yolo_model.predict(str(img_path), conf=0.25, verbose=False, device=DEVICE)\n",
    "\n",
    "    for name, act in activation_store.items():\n",
    "        n_total = act.numel()\n",
    "        n_zeros = int((act == 0).sum().item())\n",
    "        sparsity = n_zeros / n_total if n_total > 0 else 0.0\n",
    "        all_layer_sparsity.setdefault(name, []).append(sparsity)\n",
    "\n",
    "# Remove hooks after measurement\n",
    "for h in hook_handles:\n",
    "    h.remove()\n",
    "hook_handles.clear()\n",
    "print(\"Hooks removed.\")\n",
    "\n",
    "# ── Aggregate ─────────────────────────────────────────────────────────────\n",
    "layer_names  = list(all_layer_sparsity.keys())\n",
    "mean_sparsity = [np.mean(v) * 100 for v in all_layer_sparsity.values()]\n",
    "\n",
    "overall_sparsity_pct = np.mean(mean_sparsity)\n",
    "mac_reduction_pct    = overall_sparsity_pct   # zero-skip saves 1 MAC per zero\n",
    "dense_macs_est       = sum(len(v) * 1 for v in all_layer_sparsity.values()) * 1000\n",
    "effective_macs_est   = int(dense_macs_est * (1 - overall_sparsity_pct / 100))\n",
    "\n",
    "print(f\"\\n{'='*55}\")\n",
    "print(f\"  SPARSITY REPORT ({len(SPARSITY_SAMPLE)} images averaged)\")\n",
    "print(f\"{'='*55}\")\n",
    "print(f\"  Layers measured          : {len(layer_names)}\")\n",
    "print(f\"  Overall sparsity         : {overall_sparsity_pct:.1f}%\")\n",
    "print(f\"  MAC reduction (est.)     : {mac_reduction_pct:.1f}%\")\n",
    "print(f\"\\n  Top-5 sparsest layers:\")\n",
    "top5_idx = np.argsort(mean_sparsity)[::-1][:5]\n",
    "for i in top5_idx:\n",
    "    print(f\"    {layer_names[i]:<40} {mean_sparsity[i]:.1f}%\")"
   ]
  },
