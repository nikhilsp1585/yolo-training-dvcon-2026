    "import torch.nn as nn\n",
    "import numpy as np\n",
    "from ultralytics import YOLO\n",
    "\n",
    "# ── Load model ────────────────────────────────────────────────────────────\n",
    "yolo_model = YOLO(\"yolov5n.pt\")   # ~4 MB, downloads automatically\n",
    "print(f\"YOLOv5-nano loaded on {DEVICE}\")\n",
    "\n",
    "# ── Quick sanity check on one image ──────────────────────────────────────\n",
    "test_img = str(image_paths[0])\n",
    "res = yolo_model.predict(test_img, conf=0.25, verbose=False, device=DEVICE)\n",
    "print(f\"Test image: {image_paths[0].name}\")\n",
    "print(f\"Detected {len(res[0].boxes)} objects:\")\n",
    "for box in res[0].boxes[:5]:\n",
    "    cid = int(box.cls.item())\n",
    "    print(f\"  {COCO_CLASSES[cid]:<20} conf={box.conf.item():.3f}\")"
   ]
